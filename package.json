{
  "name": "dobby-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Backend Supabase para Tutor Financiero Personal (dobby-frontend)",
  "scripts": {
    "dev": "supabase start",
    "stop": "supabase stop",
    "status": "supabase status",
    "migrate:new": "supabase migration new",
    "migrate:up": "supabase migration up --local",
    "migrate:list": "supabase migration list",
    "migrate:repair": "supabase migration repair",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "db:diff": "supabase db diff",
    "db:lint": "supabase db lint",
    "seed": "supabase db reset",
    "test": "supabase test db",
    "test:functions": "deno test tests/functions/ --allow-all",
    "test:all": "npm run test && npm run test:functions",
    "types": "supabase gen types typescript --local > src/database.types.ts",
    "functions:serve": "supabase functions serve",
    "functions:deploy": "supabase functions deploy",
    "precommit": "npm run db:lint && npm run test",
    "deploy": "supabase db push && supabase functions deploy"
  },
  "engines": {
    "node": ">=20"
  }
}
