#!/bin/bash
# =============================================================
# Pre-push hook para dobby-backend
# =============================================================
# Bloquea push directo a main. Usa PR desde dev o hotfix/*.
# =============================================================

protected_branch="main"
current_branch=$(git symbolic-ref HEAD 2>/dev/null | sed 's|refs/heads/||')

if [ "$current_branch" = "$protected_branch" ]; then
  echo ""
  echo "рџљ« Push directo a '$protected_branch' no permitido."
  echo ""
  echo "Flujo correcto:"
  echo "  feat/mi-feature  в”Ђв”ЂPRв”Ђв”Ђв–¶  dev  в”Ђв”ЂPRв”Ђв”Ђв–¶  main"
  echo "  fix/mi-fix        в”Ђв”ЂPRв”Ђв”Ђв–¶  dev  в”Ђв”ЂPRв”Ђв”Ђв–¶  main"
  echo "  hotfix/urgente    в”Ђв”ЂPRв”Ђв”Ђв–¶  main + dev"
  echo ""
  echo "Si es un hotfix urgente, usa una rama hotfix/*"
  echo ""
  exit 1
fi
