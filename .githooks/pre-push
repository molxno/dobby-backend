#!/bin/bash
# =============================================================
# Pre-push hook for dobby-backend
# =============================================================
# Blocks direct push to main. Use a PR from dev or hotfix/*.
# =============================================================

protected_branch="main"
current_branch=$(git symbolic-ref HEAD 2>/dev/null | sed 's|refs/heads/||')

if [ "$current_branch" = "$protected_branch" ]; then
  echo ""
  echo "ERROR: Direct push to '$protected_branch' is not allowed."
  echo ""
  echo "Correct flow:"
  echo "  feat/my-feature  --PR-->  dev  --PR-->  main"
  echo "  fix/my-fix        --PR-->  dev  --PR-->  main"
  echo "  hotfix/urgent     --PR-->  main + dev"
  echo ""
  echo "If this is an urgent hotfix, use a hotfix/* branch."
  echo ""
  exit 1
fi
