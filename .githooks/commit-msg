#!/bin/bash
# =============================================================
# Conventional Commits validation for dobby-backend
# =============================================================
# Types: feat, fix, refactor, perf, docs, test, chore, ci
# Scopes: schema, rls, migration, function, trigger, seed, auth, deps, ci
# =============================================================

commit_msg_file="$1"
commit_msg=$(cat "$commit_msg_file")

# Regex for Conventional Commits
pattern="^(feat|fix|refactor|perf|docs|test|chore|ci)(\((schema|rls|migration|function|trigger|seed|auth|deps|ci)\))?: .{1,100}$"

# Allow merge commits
if echo "$commit_msg" | grep -qE "^Merge "; then
  exit 0
fi

# Validate first line
first_line=$(echo "$commit_msg" | head -n 1)

if ! echo "$first_line" | grep -qE "$pattern"; then
  echo ""
  echo "ERROR: Invalid commit message."
  echo ""
  echo "Expected format: <type>(<scope>): <description>"
  echo ""
  echo "  Types:  feat, fix, refactor, perf, docs, test, chore, ci"
  echo "  Scopes: schema, rls, migration, function, trigger, seed, auth, deps, ci"
  echo ""
  echo "  Examples:"
  echo "    feat(schema): add custom categories table"
  echo "    fix(rls): fix delete policy on transactions"
  echo "    test(function): add tests for delete_user_account"
  echo ""
  echo "  Your message: $first_line"
  echo ""
  exit 1
fi
