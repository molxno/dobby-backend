#!/bin/bash
# =============================================================
# Pre-commit hook for dobby-backend
# =============================================================
# 1. Basic lint for modified SQL files
# 2. Verify descriptive names on new migrations
# 3. If Edge Functions were modified, run their tests
# =============================================================

echo "Running pre-commit checks..."

# Get staged files
staged_files=$(git diff --cached --name-only --diff-filter=ACM)

# --- 1. Basic SQL lint ---
sql_files=$(echo "$staged_files" | grep '\.sql$' || true)
if [ -n "$sql_files" ]; then
  echo "Checking SQL files..."
  for file in $sql_files; do
    # Check for DROP TABLE/COLUMN without an explanatory comment
    if grep -qiE "DROP (TABLE|COLUMN)" "$file"; then
      echo "WARNING: $file contains DROP TABLE/COLUMN — make sure this is intentional"
    fi
    # Check that new tables have RLS enabled
    if grep -qiE "CREATE TABLE" "$file" && ! grep -qiE "ENABLE ROW LEVEL SECURITY" "$file"; then
      echo "ERROR: $file creates table(s) without enabling RLS"
      echo "   Add: ALTER TABLE <table> ENABLE ROW LEVEL SECURITY;"
      exit 1
    fi
  done
  echo "SQL checks passed"
fi

# --- 2. Verify migration names ---
migration_files=$(echo "$staged_files" | grep 'supabase/migrations/' || true)
if [ -n "$migration_files" ]; then
  echo "Checking migrations..."
  for file in $migration_files; do
    basename=$(basename "$file")
    # Verify it has a descriptive name (not just a timestamp)
    name_part=$(echo "$basename" | sed 's/^[0-9]*_//' | sed 's/\.sql$//')
    if [ -z "$name_part" ] || [ "$name_part" = "migration" ]; then
      echo "ERROR: Migration without a descriptive name: $basename"
      echo "   Use: supabase migration new <descriptive_name>"
      exit 1
    fi
  done
  echo "Migrations have descriptive names"
fi

# --- 3. Edge Functions tests ---
function_files=$(echo "$staged_files" | grep 'supabase/functions/' || true)
if [ -n "$function_files" ]; then
  echo "Edge Functions modified, running tests..."
  if command -v deno &> /dev/null && [ -d "tests/functions" ]; then
    deno test tests/functions/ --allow-all
    if [ $? -ne 0 ]; then
      echo "ERROR: Edge Functions tests failed"
      exit 1
    fi
    echo "Edge Functions tests passed"
  else
    echo "WARNING: Deno not available or no tests found — skipping"
  fi
fi

echo "Pre-commit checks completed"
